# pingway configuration — copy to .env next to install.sh / run.sh /
# docker-compose.yml and it is picked up automatically.
# All values optional; see README for the full list.

TZ=America/New_York

# Name:host:tier,... (tier: 1=LAN, 2=ISP side, 3=internet anchor)
TARGETS=LAN Gateway:192.168.1.1:1,WiFi Hub:192.168.1.54:1,ISP First Hop:142.254.214.149:2,Cloudflare:1.1.1.1:3,Google DNS:8.8.8.8:3

SPEEDTEST_ENGINE=librespeed
SPEEDTEST_INTERVAL_MINUTES=20
#SPEEDTEST_ENABLED=true
#OOKLA_ACCEPT_EULA=false
#CONFIG_LOCK=false
#PING_INTERVAL_MS=1000
#LOG_FORMAT=json

# --- Synthetic call probe (optional) ---
# An RTP-shaped UDP stream to reflectors OUTSIDE your network. Measures
# what a real video call would experience: loss, jitter, freezes, and a
# MOS score. Run ghcr.io/jasondcamp/pingway-reflector on a cheap VPS.
# Format: Name:host[:port],...  (port defaults to 15000)
#CALLPROBE_REFLECTORS=DO-NYC:203.0.113.10:15000
# Packets per second per reflector (default 50 ≈ 9KB/s each way)
#CALLPROBE_PPS=50
